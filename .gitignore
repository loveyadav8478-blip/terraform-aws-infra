# Local .terraform directories
**/.terraform/*

# Terraform lock/state files (state lives remotely in S3)
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Sensitive variable files - never commit real values
*.tfvars
!*.tfvars.example

# Terraform plan output
*.tfplan
tfplan

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

.terraform.lock.hcl

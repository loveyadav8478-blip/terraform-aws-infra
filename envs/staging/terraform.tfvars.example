
aws_region   = "us-east-1"
project_name = "myapp"
environment  = "dev"

instance_type    = "t3.micro"
desired_capacity = 2
min_size         = 2
max_size         = 3

db_instance_class = "db.t3.micro"
db_multi_az       = false

# Pass these via TF_VAR_db_username / TF_VAR_db_password
# environment variables or a secrets manager - do NOT hardcode here.
# db_username = ""
# db_password = ""
